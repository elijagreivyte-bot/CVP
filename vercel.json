{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "functions": {
    "api/analyze.js": { "maxDuration": 60 },
    "api/analyze-agents.js": { "maxDuration": 60 },
    "api/analyze-start.js": { "maxDuration": 30 },
    "api/analyze-continue.js": { "maxDuration": 60 },
    "api/tender-questionnaire.js": { "maxDuration": 60 },
    "api/chat.js": { "maxDuration": 60 },
    "api/po-question.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/reminders", "schedule": "0 8 * * *" },
    { "path": "/api/daily-report", "schedule": "30 7 * * *" },
    { "path": "/api/weekly-quality-report", "schedule": "0 6 * * 1" }
  ]
}
